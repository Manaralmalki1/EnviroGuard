      "source": [
        "merged_df = pd.concat(\n",
        "    [urban_df, beijing_df, openaq_df],\n",
        "    ignore_index=True\n",
        ")\n",
        "\n",
        "merged_df = merged_df.sort_values(\"timestamp\")"
