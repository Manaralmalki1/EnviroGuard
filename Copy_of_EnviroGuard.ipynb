      "source": [
        "urban_df[\"timestamp\"] = urban_df[\"timestamp\"].dt.tz_localize(\"UTC\")\n",
        "beijing_df[\"timestamp\"] = beijing_df[\"timestamp\"].dt.tz_localize(\"UTC\")"
      ]
    },
    {
